# StudyQuest FastAPI backend
MONGODB_URI=mongodb+srv://USER:PASSWORD@CLUSTER.mongodb.net/?retryWrites=true&w=majority
MONGODB_DB_NAME=studyquest
STUDYQUEST_ADMIN_KEY=replace-with-a-long-random-admin-key
STUDYQUEST_JWT_SECRET=replace-with-a-long-random-token-secret
CORS_ORIGINS=https://your-github-username.github.io,http://127.0.0.1:4177

# Optional AI fallback for cache misses
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash

# Optional tuning
MONGODB_VECTOR_INDEX=quest_solution_vector_index
STUDYQUEST_VECTOR_DIMENSIONS=256
STUDYQUEST_SPRINT_MINUTES=30
STUDYQUEST_AUTH_TOKEN_HOURS=336
